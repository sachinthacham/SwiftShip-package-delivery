<?xml version="1.0" encoding="utf-8"?>
<configuration>
  <packageSources>
    <clear />
    <add key="nuget.org" value="https://api.nuget.org/v3/index.json" protocolVersion="3" />
  </packageSources>
  <config>
    <!-- Reduce parallel downloads (helps on slow/unstable networks during Docker build) -->
    <add key="maxHttpRequestsPerSource" value="4" />
  </config>
</configuration>
