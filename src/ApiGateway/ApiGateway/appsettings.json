{
  "Logging": {
    "LogLevel": {
      "Default": "Information",
      "Microsoft.AspNetCore": "Warning"
    }
  },
  "ReverseProxy": {
    "Routes": {
      "identity-route": {
        "ClusterId": "identity-cluster",
        "Match": {
          "Path": "/identity/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/identity"
          }
        ]
      },
      "package-route": {
        "ClusterId": "package-cluster",
        "Match": {
          "Path": "/package/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/package"
          }
        ]
      },
      "shipment-route": {
        "ClusterId": "shipment-cluster",
        "Match": {
          "Path": "/shipment/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/shipment"
          }
        ]
      },
      "tracking-route": {
        "ClusterId": "tracking-cluster",
        "Match": {
          "Path": "/tracking/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/tracking"
          }
        ]
      },
      "driver-route": {
        "ClusterId": "driver-cluster",
        "Match": {
          "Path": "/driver/{**catch-all}"
        },
        "Transforms": [
          {
            "PathRemovePrefix": "/driver"
          }
        ]
      }
    },
    "Clusters": {
      "identity-cluster": {
        "Destinations": {
          "identity-service": {
            "Address": "http://localhost:5001/"
          }
        }
      },
      "package-cluster": {
        "Destinations": {
          "package-service": {
            "Address": "http://localhost:5002/"
          }
        }
      },
      "shipment-cluster": {
        "Destinations": {
          "shipment-service": {
            "Address": "http://localhost:5003/"
          }
        }
      },
      "tracking-cluster": {
        "Destinations": {
          "tracking-service": {
            "Address": "http://localhost:5004/"
          }
        }
      },
      "driver-cluster": {
        "Destinations": {
          "driver-service": {
            "Address": "http://localhost:5005/"
          }
        }
      }
    }
  },
  "AllowedHosts": "*"
}
